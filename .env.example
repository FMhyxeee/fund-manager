APP_NAME=fund-manager
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/fund_manager.db
REPORT_OUTPUT_DIR=./var/reports
DEFAULT_PORTFOLIO_NAME=main

OPENCLAW_BASE_URL=http://localhost:8081
OPENCLAW_WORKSPACE=fund-manager

OPENAI_PROVIDER_ENABLED=true
GLM_PROVIDER_ENABLED=false
